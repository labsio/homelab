# Cloudflare API token for DNS-01 ACME challenge
# Scope: Zone.DNS:Edit + Zone.Zone:Read on your zone
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# Email for Let's Encrypt account (expiry notifications)
ACME_EMAIL=you@example.com

# Your public domain — used for service subdomains (links.${DOMAIN}, rss.${DOMAIN}, etc.)
DOMAIN=example.com

# Proxmox host reachable from the Caddy container (host:port)
# Example: 192.168.1.10:8006 or proxmox.internal:8006
PROXMOX_HOST=proxmox.internal:8006

# Timezone for container logs
TZ=UTC
