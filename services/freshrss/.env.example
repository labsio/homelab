# Timezone for both containers and feed fetch schedule
TZ=UTC

# Feed refresh schedule (cron minute expression)
# Default: every 15 minutes. Use */5 for more frequent, 0 for hourly.
CRON_MIN=*/15

# Trusted reverse proxy CIDR — required so FreshRSS honors X-Forwarded-*
# headers from Caddy. Default covers Docker's 172.16/12 bridge range.
TRUSTED_PROXY=172.16.0.0/12
